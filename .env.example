# ATS Resume Analyzer

# =========================
# Server
# =========================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# =========================
# OpenAI
# =========================
# Create an API key at https://platform.openai.com/
OPENAI_API_KEY=sk-...           # required for /api/analyze and resume generation

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=...          # From @BotFather on Telegram
TELEGRAM_WEBHOOK_URL=...       # Your domain + /webhook (optional; polling is used in v1)

# =========================
# File Storage
# =========================
# Uploads (multer temp files). Auto-cleanup runs periodically.
UPLOAD_DIR=./uploads

# Generated artifacts:
# - analysis JSON records
# - generated resume PDFs
GENERATED_DIR=./generated

MAX_FILE_SIZE_MB=10
FILE_CLEANUP_HOURS=1

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

